{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": [
            "ES2020"
        ],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "outDir": "dist/server",
        "rootDir": "src/server",
        "declaration": true
    },
    "include": [
        "src/server"
    ],
    "exclude": [
        "node_modules"
    ]
}